<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # 1. Prevent access to sensitive files and directories (.env, .git, etc.)
    RewriteRule ^\.|/\. - [F]
    
    # 2. Block direct access to configuration and log files
    RewriteRule \.(env|log|sqlite|xml|json|lock|yaml|yml|md|bak|sql)$ - [F,L]
    RewriteRule ^(composer|package)\.(json|lock) - [F,L]
    
    # 2b. Block direct access to core Laravel directories
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/.*)?$ - [F,L]

    # 3. Force HTTPS (Common for InfinityFree and Cloudflare)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 4. Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 5. Handle Front Controller...
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L,QSA]
</IfModule>
